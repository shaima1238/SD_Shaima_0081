        "\n",
        "user_id = input(\"Enter User ID: \")\n",
        "password = input(\"Enter Password: \")\n",
        "\n",
        "# Check agar ID aur password sahi hai\n",
        "if user_id == \"admin\" and password == \"1234\":\n",
        "    print(\"\\nLogin Successful! Welcome to your Expense Tracker.\")\n",
        "\n",
        "    # 2. Taking inputs for the 4 expense categories\n",
        "    print(\"\\nPlease enter your expenses below:\")\n",
        "    food_expense = int(input(\"Food Expense: ₹\"))\n",
        "    movie_expense = int(input(\"Movie Expense: ₹\"))\n",
        "    travel_expense = int(input(\"Travelling Expense: ₹\"))\n",
        "    other_expense = int(input(\"Other Expense: ₹\")) # 4th category\n",
        "\n",
        "    # 3. Calculating the total amount\n",
        "    total = food_expense + movie_expense + travel_expense + other_expense\n",
        "\n",
        "    # 4. Printing the final summary\n",
        "    print(\"\\n--- Your Expense Summary ---\")\n",
        "    print(f\"🍔 Food: ₹{food_expense}\")\n",
        "    print(f\"🎬 Movie: ₹{movie_expense}\")\n",
        "    print(f\"🚌 Travelling: ₹{travel_expense}\")\n",
        "    print(f\"📦 Other: ₹{other_expense}\")\n",
        "    print(\"----------------------------\")\n",
        "    print(f\"💰 Total Expense: ₹{total}\")\n",
        "\n",
        "else:\n",
        "    print(\"\\nLogin Failed! Incorrect User ID or Password.\")"
